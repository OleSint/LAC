{
  "name": "lac",
  "version": "2.1.0",
  "description": "LAN Messenger mit mehreren Kontakten und automatischer Geräte-Erkennung",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.local.lac",
    "productName": "LAC",
    "files": [
      "main.js",
      "preload.js",
      "net/**/*",
      "store/**/*",
      "renderer/**/*"
    ],
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" },
    "mac": { "target": "dmg" }
  }
}
